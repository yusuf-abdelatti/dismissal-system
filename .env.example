VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key

# The service role key must NEVER be prefixed with VITE_ and must never live
# in a file loaded by the frontend build. It is only used by Supabase Edge
# Functions (set via `supabase secrets set SUPABASE_SERVICE_ROLE_KEY=...`)
# and by the Supabase CLI locally, never by src/ code.
