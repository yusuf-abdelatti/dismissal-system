VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key

# The service role key must NEVER be prefixed with VITE_ and must never be
# read by anything under src/ (Vite would bundle it into the browser build).
# It's used only by the /api/*.js serverless functions and Supabase Edge
# Functions. Needed locally only if running those via `vercel dev`.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
